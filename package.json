{
  "name": "@bsawang/codebrain",
  "version": "0.1.3",
  "description": "系统级 AI 编码 Agent 自进化错误记忆框架",
  "keywords": [
    "ai",
    "coding-agent",
    "error-tracking",
    "self-evolution",
    "claude-code",
    "devtools"
  ],
  "author": "bsawang",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bsawang/codeBrain"
  },
  "homepage": "https://github.com/bsawang/codeBrain#readme",
  "bin": {
    "codebrain": "dist/cli/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && node -e \"var f=require('fs'),p=require('path');f.mkdirSync('dist/webui',{recursive:true});f.copyFileSync('src/webui/index.html','dist/webui/index.html')\"",
    "dev": "tsc --watch",
    "start": "node dist/cli/index.js",
    "prepublishOnly": "npm run build && node -e \"['dist/test-integration.js','dist/test-integration.js.map','dist/test-integration.d.ts','dist/test-live-llm.js','dist/test-live-llm.js.map','dist/test-live-llm.d.ts'].forEach(x=>{try{require('fs').unlinkSync(x)}catch(e){}})\""
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.0",
    "figlet": "^1.11.0",
    "sql.js": "^1.11.0",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@types/figlet": "^1.7.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=22"
  }
}
